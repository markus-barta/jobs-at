# OpenRouter API key — get one at https://openrouter.ai/
OPENROUTER_API_KEY=your_key_here

# SSH target for the deploy script (optional)
# Format: "user@host -p port"  e.g. "admin@myserver.example.com -p 22"
DEPLOY_SSH=

# Directory on the server that contains docker-compose.yml (optional, default: ~/docker)
DEPLOY_COMPOSE_DIR=~/docker
